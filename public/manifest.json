{
  "manifest_version": 3,
  "name": "InsightIQ",
  "version": "1.0.0",
  "description": "A professional AI-powered Chrome extension for analyzing webpages and generating insights.",
  "permissions": ["activeTab", "storage", "scripting", "tabs", "clipboardRead", "sidePanel", "windows"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "InsightIQ",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "64": "icons/icon64.png",
      "128": "icons/icon128.png",
      "256": "icons/icon256.png",
      "512": "icons/icon512.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "64": "icons/icon64.png",
    "128": "icons/icon128.png",
    "256": "icons/icon256.png",
    "512": "icons/icon512.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
